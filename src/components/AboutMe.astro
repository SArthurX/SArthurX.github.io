---
import Card from "./Card/index.astro";
import { SITE } from "../site-config";

const stack = [
  { label: "C", category: "lang" },
  { label: "C++", category: "lang" },
  { label: "Python", category: "lang" },
  { label: "Shell Script", category: "lang" },
  { label: "Embedded Linux", category: "embedded" },
  { label: "RTOS", category: "embedded" },
  { label: "Ambarella SoC", category: "embedded" },
  { label: "GStreamer", category: "embedded" },
  { label: "Video Pipeline", category: "embedded" },
  { label: "AI Inference", category: "embedded" },
  { label: "Darknet/YOLO", category: "ai" },
  { label: "OpenCV", category: "ai" },
  { label: "Valgrind", category: "tools" },
  { label: "GDB", category: "tools" },
  { label: "Git", category: "tools" },
  { label: "Docker", category: "tools" },
  { label: "Linux Kernel", category: "system" },
  { label: "TCP/UDP Sockets", category: "system" },
  { label: "IPC / Shared Memory", category: "system" },
  { label: "Astro", category: "web" },
  { label: "JavaScript", category: "web" },
  { label: "TypeScript", category: "web" },
];
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-6" title="About me">
  <div class="flex flex-col gap-4">
    <p class="text-sm font-light">
      Hi, I'm <b class="font-bold">{SITE.author.firstName}</b>, an
      {SITE.author.jobTitle} from {SITE.location.countryName}.
    </p>

    <div class="flex flex-col gap-2">
      <span
        class="text-[10px] uppercase tracking-widest text-darkslate-300 font-medium"
        >Stack & tools</span
      >
      <div class="flex flex-wrap gap-1.5">
        {
          stack.map(({ label }) => (
            <span class="text-[11px] px-2 py-0.5 rounded-full border border-darkslate-400 text-darkslate-100 hover:border-primary-500 hover:text-white transition-colors duration-150 cursor-default">
              {label}
            </span>
          ))
        }
      </div>
    </div>

    <p class="text-sm font-light">
      I specialize in building robust embedded systems, real-time video
      processing, and AI inference on edge devices. Passionate about low-level
      programming and making hardware do amazing things.
    </p>
  </div>
</Card>
